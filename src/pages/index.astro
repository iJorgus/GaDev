---
/**
 * ═══════════════════════════════════════════════════════
 *  GaDev — Landing Page Principal
 *  Agencia boutique de ingeniería de software
 *  para el comercio local de Cádiz
 * ═══════════════════════════════════════════════════════
 *
 *  Stack: Astro 6.x · Tailwind CSS v4 · Lucide Icons (CDN)
 *  Estética: Dark Room + Gradiente "Cádiz Sunset"
 *  SEO: OpenGraph, Twitter Cards, Schema.org
 * ═══════════════════════════════════════════════════════
 */

import Layout from "../layouts/Layout.astro";
import Preloader from "../components/Preloader.astro";
import Navbar from "../components/Navbar.astro";

import Hero from "../components/Hero.astro";
import PuertaTierraCanvas from "../components/PuertaTierraCanvas.astro";
import Services from "../components/Services.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";

/** Datos SEO */
const seo = {
  title: "GaDev — Ingeniería de Software en Cádiz | Desarrollo Web Local",
  description:
    "Agencia boutique de ingeniería de software para el comercio local de Cádiz. Desarrollamos aplicaciones web, e-commerce y soluciones digitales a medida.",
  url: "https://gadev.es",
  image: "https://gadev.es/og-image.jpg",
};
---

<Layout
  title={seo.title}
  description={seo.description}
  url={seo.url}
  image={seo.image}
>
  <!-- Preloader -->
  <Preloader />

  <!-- Main Content Container — Oculta el Footer Reveal -->
  <main
    id="main-content"
    class="relative z-10 bg-[#030303] overflow-hidden rounded-b-[2.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.8)] pb-10"
  >

    <Navbar />
    <Hero />
    <PuertaTierraCanvas />
    <Services />
    <Projects />
    <Contact />
  </main>

  <!-- Footer Reveal (fuera del main para el efecto reveal) -->
  <Footer />
</Layout>
