---
/**
 * ═══════════════════════════════════════════════════════
 *  GaDev — Landing Page Principal
 *  Agencia boutique de ingeniería de software
 *  para el comercio local de Cádiz
 * ═══════════════════════════════════════════════════════
 *
 *  Stack: Astro 6.x · Tailwind CSS v4 · Lucide Icons (CDN)
 *  Estética: Dark Room + Gradiente "Cádiz Sunset"
 *  SEO: OpenGraph, Twitter Cards, Schema.org
 * ═══════════════════════════════════════════════════════
 */

// ─── Datos Estructurados ─────────────────────────────
// Se definen en el frontmatter para mantener el HTML limpio

import Hero from "../components/Hero.astro";

/** Servicios ofrecidos por GaDev */
const servicios = [
  {
    id: "web-apps",
    titulo: "Aplicaciones Web",
    descripcion:
      "Plataformas digitales a medida que transforman la forma en que tu negocio gaditano se conecta con sus clientes. Desde paneles de administración hasta apps progresivas.",
    icono: "globe",
    gridClass: "md:col-span-2",
    acento: "from-[#0077b6] to-[#0096c7]",
    destacado: true,
    features: [
      "Apps progresivas (PWA)",
      "Paneles de administración",
      "APIs robustas",
    ],
  },
  {
    id: "ecommerce",
    titulo: "E-Commerce Local",
    descripcion:
      "Tiendas online con sabor a Cádiz. Vende tus productos al mundo sin perder tu identidad local.",
    icono: "shopping-bag",
    gridClass: "",
    acento: "from-[#0096c7] to-[#48cae4]",
  },
  {
    id: "booking",
    titulo: "Reservas y Citas",
    descripcion:
      "Sistemas de reserva inteligentes para hostelería, salud y servicios profesionales de Cádiz.",
    icono: "calendar-check",
    gridClass: "",
    acento: "from-[#48cae4] to-[#90e0ef]",
  },
  {
    id: "automatizacion",
    titulo: "Automatización",
    descripcion:
      "Eliminamos las tareas repetitivas de tu negocio con flujos de trabajo inteligentes y conectados.",
    icono: "cpu",
    gridClass: "",
    acento: "from-[#ee9b00] to-[#ffb703]",
  },
  {
    id: "seo-local",
    titulo: "SEO & Presencia Digital",
    descripcion:
      "Haz que te encuentren en Cádiz. Posicionamiento local y estrategia digital para crecer.",
    icono: "search",
    gridClass: "",
    acento: "from-[#0077b6] to-[#ee9b00]",
  },
  {
    id: "consultoria",
    titulo: "Consultoría Tech",
    descripcion:
      "Asesoramiento técnico para digitalizar tu negocio con la solución correcta, sin gastar de más.",
    icono: "lightbulb",
    gridClass: "md:col-span-2",
    acento: "from-[#ffb703] to-[#ee9b00]",
    destacado: true,
    features: [
      "Auditoría tecnológica",
      "Plan de digitalización",
      "Presupuesto sin sorpresas",
    ],
  },
];

/** Proyectos destacados / Testimonials */
const proyectos = [
  {
    nombre: "Bar El Faro",
    tipo: "Sistema de Reservas",
    descripcion:
      "Digitalización completa del sistema de reservas con carta digital y gestión de mesas en tiempo real.",
    resultado: "+40% reservas online",
  },
  {
    nombre: "Pescadería Bahía",
    tipo: "E-Commerce",
    descripcion:
      "Tienda online con pedidos a domicilio y gestión de stock fresco para productos del mar gaditano.",
    resultado: "Ventas x3 en 6 meses",
  },
  {
    nombre: "Clínica Santa María",
    tipo: "App de Gestión",
    descripcion:
      "Plataforma de gestión de citas, historial médico digital y comunicación paciente-doctor.",
    resultado: "-60% llamadas telefónicas",
  },
];

/** Estadísticas clave */
const stats = [
  { valor: "100%", label: "Compromiso", prefijo: "+" },
  { valor: "4", label: "Ingenieros", prefijo: "" },
  { valor: "∞", label: "Café consumido", prefijo: "" },
  { valor: "Local", label: "Soluciones de Cádiz", prefijo: "100%" },
];

/** Links de navegación */
const navLinks = [
  { label: "Servicios", href: "#servicios" },
  { label: "Proyectos", href: "#proyectos" },
  { label: "Nosotros", href: "#nosotros" },
  { label: "Contacto", href: "#contacto" },
];

/** Datos SEO */
const seo = {
  title: "GaDev — Ingeniería de Software en Cádiz | Desarrollo Web Local",
  description:
    "Agencia boutique de ingeniería de software para el comercio local de Cádiz. Desarrollamos aplicaciones web, e-commerce y soluciones digitales a medida.",
  url: "https://gadev.es",
  image: "https://gadev.es/og-image.jpg",
};
---

<!doctype html>
<html lang="es">
  <head>
    <!-- ─── Meta Base ──────────────────────────────────── -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- ─── SEO ────────────────────────────────────────── -->
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta
      name="keywords"
      content="desarrollo web Cádiz, ingeniería software Cádiz, aplicaciones web, e-commerce local, digitalización comercio Cádiz, GaDev"
    />
    <meta name="author" content="GaDev" />
    <link rel="canonical" href={seo.url} />

    <!-- ─── OpenGraph ──────────────────────────────────── -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.url} />
    <meta property="og:image" content={seo.image} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="GaDev" />

    <!-- ─── Twitter Cards ──────────────────────────────── -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.image} />

    <!-- ─── Favicon ────────────────────────────────────── -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- ─── Fuentes (Inter de Google Fonts) ─────────────── -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <!-- ─── Estilos Globales ───────────────────────────── -->
    <link rel="stylesheet" href="/src/styles/global.css" />

    <!-- ─── Vendor Scripts (GSAP & Lenis) ────────────────── -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
    ></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
    ></script>
    <script
      src="https://unpkg.com/@studio-freight/lenis@1.0.39/dist/lenis.min.js"
    ></script>

    <!-- ─── Schema.org (JSON-LD) ────────────────────────── -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        name: "GaDev",
        description: seo.description,
        url: seo.url,
        areaServed: {
          "@type": "City",
          name: "Cádiz",
        },
        serviceType: [
          "Desarrollo Web",
          "E-Commerce",
          "Consultoría Tecnológica",
        ],
      })}
    />
  </head>

  <body class="relative min-h-screen">
    <!-- ═══════════════════════════════════════════════════
        PRELOADER — Scramble text + 000→100 counter
        ═══════════════════════════════════════════════════ -->
    <div
      id="preloader"
      class="fixed inset-0 z-[60000] flex flex-col items-center justify-center gap-6 transition-opacity duration-500"
      style="background: #030303;"
    >
      <!-- Scramble title -->
      <div
        id="pre-title"
        class="gradient-text text-6xl font-black tracking-tight sm:text-7xl md:text-8xl lg:text-9xl"
        style="-webkit-text-fill-color: transparent;"
      >
        GaDev
      </div>
      <!-- Counter -->
      <span
        id="pre-num"
        class="font-mono text-xs tracking-[0.35em] text-white/20"
      >
        000
      </span>
      <!-- Progress line -->
      <div class="h-px w-36 overflow-hidden rounded-full bg-white/[0.06]">
        <div
          id="pre-line"
          class="h-full w-0 rounded-full transition-none"
          style="background: linear-gradient(90deg, #0077b6, #0096c7, #ee9b00);"
        >
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════════
        MAIN CONTENEDOR — Oculta el Footer Reveal
        ═══════════════════════════════════════════════════ -->
    <main
      id="main-content"
      class="relative z-10 bg-[#030303] overflow-hidden rounded-b-[2.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.8)] pb-10"
    >
      <!-- ═══════════════════════════════════════════════════
        GLOWS DE FONDO — Resplandores radiales decorativos
        ═══════════════════════════════════════════════════ -->
      <div
        class="pointer-events-none fixed inset-0 z-0 overflow-hidden"
        aria-hidden="true"
      >
        <!-- Glow superior izquierdo (azul oceánico) -->
        <div
          class="animate-pulse-glow absolute -top-40 -left-40 h-[600px] w-[600px] rounded-full opacity-40"
          style="background: radial-gradient(circle, rgba(0,119,182,0.15) 0%, transparent 70%);"
        >
        </div>
        <!-- Glow inferior derecho (ámbar) -->
        <div
          class="animate-pulse-glow absolute -right-40 -bottom-40 h-[500px] w-[500px] rounded-full opacity-30"
          style="background: radial-gradient(circle, rgba(238,155,0,0.12) 0%, transparent 70%); animation-delay: 2s;"
        >
        </div>
        <!-- Glow central sutil -->
        <div
          class="absolute top-1/2 left-1/2 h-[800px] w-[800px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-15"
          style="background: radial-gradient(circle, rgba(0,150,199,0.08) 0%, transparent 60%);"
        >
        </div>
      </div>

      <!-- ═══════════════════════════════════════════════════
        NAVBAR — Con efecto scroll-blur
        ═══════════════════════════════════════════════════ -->
      <nav
        id="navbar"
        class="fixed top-0 right-0 left-0 z-50 transition-all duration-500"
        role="navigation"
        aria-label="Navegación principal"
      >
        <div
          class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8"
        >
          <!-- Logo -->
          <a
            href="/"
            class="group flex items-center gap-3"
            aria-label="GaDev — Inicio"
          >
            <img
              src="/favicon.ico"
              alt="GaDev Logo"
              class="h-9 w-9 transition-transform duration-300 group-hover:scale-110"
              width="36"
              height="36"
            />
            <span class="gradient-text text-xl font-bold tracking-tight"
              >GaDev</span
            >
          </a>

          <!-- Links Desktop -->
          <div class="hidden items-center gap-8 md:flex">
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class="relative text-sm font-medium text-text-secondary transition-colors duration-300 hover:text-text-primary after:absolute after:-bottom-1 after:left-0 after:h-px after:w-0 after:bg-gradient-to-r after:from-cadiz-ocean after:to-cadiz-amber after:transition-all after:duration-300 hover:after:w-full"
                >
                  {link.label}
                </a>
              ))
            }
            <a
              href="#contacto"
              class="glass gradient-border rounded-full px-5 py-2 text-sm font-semibold text-text-primary transition-all duration-300 hover:scale-105"
            >
              Hablemos
            </a>
          </div>

          <!-- Hamburger Mobile -->
          <button
            id="mobile-menu-btn"
            class="relative z-50 flex h-10 w-10 flex-col items-center justify-center gap-1.5 md:hidden"
            aria-label="Abrir menú de navegación"
            aria-expanded="false"
          >
            <span
              class="hamburger-line block h-0.5 w-6 rounded-full bg-text-primary transition-all duration-300"
            ></span>
            <span
              class="hamburger-line block h-0.5 w-6 rounded-full bg-text-primary transition-all duration-300"
            ></span>
            <span
              class="hamburger-line block h-0.5 w-4 rounded-full bg-text-primary transition-all duration-300"
            ></span>
          </button>
        </div>

        <!-- Mobile Menu Overlay -->
        <div
          id="mobile-menu"
          class="pointer-events-none fixed inset-0 z-40 flex items-center justify-center opacity-0 transition-all duration-500 md:hidden"
          style="background: rgba(3,3,3,0.97); backdrop-filter: blur(24px);"
        >
          <div class="flex flex-col items-center gap-8">
            {
              navLinks.map((link) => (
                <a
                  href={link.href}
                  class="mobile-nav-link text-3xl font-bold text-text-primary transition-all duration-300 hover:text-cadiz-amber"
                >
                  {link.label}
                </a>
              ))
            }
            <a
              href="#contacto"
              class="glass gradient-border mt-4 rounded-full px-8 py-3 text-lg font-semibold text-text-primary"
            >
              Hablemos
            </a>
          </div>
        </div>
      </nav>

      <!-- ═══════════════════════════════════════════════════
        HERO SECTION — Mesh Gradient animado de fondo
        ═══════════════════════════════════════════════════ -->
      <Hero />

      <!-- ═══════════════════════════════════════════════════
        STATS SECTION — Contadores con animación
        ═══════════════════════════════════════════════════ -->
      <section
        id="nosotros"
        class="relative z-10 py-20"
        aria-label="Estadísticas de GaDev"
      >
        <div class="mx-auto max-w-6xl px-6 lg:px-8">
          <div
            class="glass grid grid-cols-2 gap-6 rounded-3xl p-8 md:grid-cols-4 md:gap-8 md:p-12"
          >
            <!-- Stat: Compromiso -->
            <div
              class="stat-item flex flex-col items-center text-center"
              data-animate
            >
              <span class="gradient-text mb-2 text-4xl font-black md:text-5xl"
                >+100%</span
              >
              <span class="text-sm font-medium text-text-secondary"
                >Compromiso</span
              >
            </div>
            <!-- Stat: Ingenieros -->
            <div
              class="stat-item flex flex-col items-center text-center"
              data-animate
            >
              <span class="gradient-text mb-2 text-4xl font-black md:text-5xl"
                >4</span
              >
              <span class="text-sm font-medium text-text-secondary"
                >Ingenieros</span
              >
            </div>
            <!-- Stat: Café -->
            <div
              class="stat-item flex flex-col items-center text-center"
              data-animate
            >
              <span class="gradient-text mb-2 text-4xl font-black md:text-5xl"
                >∞</span
              >
              <span class="text-sm font-medium text-text-secondary"
                >Café consumido</span
              >
            </div>
            <!-- Stat: Soluciones -->
            <div
              class="stat-item flex flex-col items-center text-center"
              data-animate
            >
              <span class="gradient-text mb-2 text-4xl font-black md:text-5xl"
                >100%</span
              >
              <span class="text-sm font-medium text-text-secondary"
                >Soluciones Locales</span
              >
            </div>
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
        BENTO SERVICES — Grid interactivo de servicios
        ═══════════════════════════════════════════════════ -->
      <section
        id="servicios"
        class="relative z-10 py-24"
        aria-label="Nuestros servicios"
      >
        <div class="mx-auto max-w-6xl px-6 lg:px-8">
          <!-- Header de sección -->
          <div class="mb-16 text-center" data-animate>
            <span
              class="inline-block mb-4 text-sm font-semibold tracking-widest text-cadiz-amber uppercase"
              >Lo que hacemos</span
            >
            <h2
              class="mb-4 text-3xl font-bold tracking-tight md:text-4xl lg:text-5xl"
            >
              Servicios <span class="gradient-text">a tu medida</span>
            </h2>
            <p class="mx-auto max-w-2xl text-text-secondary">
              Cada negocio gaditano es único. Por eso nuestras soluciones se
              diseñan desde cero, adaptadas a tus necesidades reales.
            </p>
          </div>

          <!-- Bento Grid -->
          <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
            {
              servicios.map((servicio, index) => (
                <article
                  class={`glow-card group relative cursor-pointer overflow-hidden rounded-2xl p-6 transition-all duration-500 hover:scale-[1.02] md:p-8 ${servicio.gridClass}`}
                  data-glow
                  data-animate
                  id={`servicio-${servicio.id}`}
                  role="article"
                  aria-label={`Servicio: ${servicio.titulo}`}
                >
                  {/* Spotlight inner glow layer */}
                  <div data-glow aria-hidden="true" />
                  {/* Glow decorativo de fondo */}
                  <div
                    class={`absolute -right-4 -bottom-4 h-32 w-32 rounded-full bg-gradient-to-br ${servicio.acento} opacity-5 transition-all duration-500 group-hover:opacity-10 group-hover:scale-125`}
                    aria-hidden="true"
                  />

                  {/* Icono con gradiente */}
                  <div
                    class={`mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br ${servicio.acento} p-2.5 shadow-lg transition-transform duration-300 group-hover:scale-110`}
                  >
                    {/* Flecha genérica — se muestra para todos */}
                    <svg
                      class="h-6 w-6 text-white"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      {servicio.id === "web-apps" && (
                        <>
                          <circle cx="12" cy="12" r="10" />
                          <path d="M2 12h20" />
                          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                        </>
                      )}
                      {servicio.id === "ecommerce" && (
                        <>
                          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                          <path d="M3 6h18" />
                          <path d="M16 10a4 4 0 0 1-8 0" />
                        </>
                      )}
                      {servicio.id === "booking" && (
                        <>
                          <rect width="18" height="18" x="3" y="4" rx="2" />
                          <path d="M16 2v4" />
                          <path d="M8 2v4" />
                          <path d="M3 10h18" />
                          <path d="m9 16 2 2 4-4" />
                        </>
                      )}
                      {servicio.id === "automatizacion" && (
                        <>
                          <rect width="16" height="16" x="4" y="4" rx="2" />
                          <rect width="6" height="6" x="9" y="9" rx="1" />
                          <path d="M15 2v2" />
                          <path d="M15 20v2" />
                          <path d="M2 15h2" />
                          <path d="M2 9h2" />
                          <path d="M20 15h2" />
                          <path d="M20 9h2" />
                          <path d="M9 2v2" />
                          <path d="M9 20v2" />
                        </>
                      )}
                      {servicio.id === "seo-local" && (
                        <>
                          <circle cx="11" cy="11" r="8" />
                          <path d="m21 21-4.3-4.3" />
                        </>
                      )}
                      {servicio.id === "consultoria" && (
                        <>
                          <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
                          <path d="M9 18h6" />
                          <path d="M10 22h4" />
                        </>
                      )}
                    </svg>
                  </div>

                  {/* Contenido */}
                  <h3 class="mb-2 text-lg font-bold text-text-primary md:text-xl">
                    {servicio.titulo}
                  </h3>
                  <p class="mb-4 text-sm leading-relaxed text-text-secondary md:text-base">
                    {servicio.descripcion}
                  </p>

                  {/* Feature badges para tarjetas destacadas */}
                  {servicio.destacado && servicio.features && (
                    <div class="mb-4 flex flex-wrap gap-2">
                      {servicio.features.map((feature: string) => (
                        <span class="inline-flex items-center gap-1 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-text-secondary">
                          <svg
                            class="h-3 w-3 text-cadiz-ocean"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                          >
                            <polyline points="20 6 9 17 4 12" />
                          </svg>
                          {feature}
                        </span>
                      ))}
                    </div>
                  )}

                  {/* Flecha de acción */}
                  <div class="mt-auto flex items-center gap-1 text-sm font-medium text-cadiz-ocean transition-all duration-300 group-hover:text-cadiz-amber group-hover:gap-2">
                    <span>Saber más</span>
                    <svg
                      class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M5 12h14" />
                      <path d="m12 5 7 7-7 7" />
                    </svg>
                  </div>
                </article>
              ))
            }
          </div>
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
        PROYECTOS — Casos de éxito
        ═══════════════════════════════════════════════════ -->
      <section
        id="proyectos"
        class="relative z-10 py-24"
        aria-label="Proyectos destacados"
      >
        <div class="mx-auto max-w-6xl px-6 lg:px-8">
          <!-- Header de sección -->
          <div class="mb-16 text-center" data-animate>
            <span
              class="inline-block mb-4 text-sm font-semibold tracking-widest text-cadiz-amber uppercase"
              >Portfolio</span
            >
            <h2
              class="mb-4 text-3xl font-bold tracking-tight md:text-4xl lg:text-5xl"
            >
              Proyectos que <span class="gradient-text"
                >hablan por sí solos</span
              >
            </h2>
            <p class="mx-auto max-w-2xl text-text-secondary">
              Negocios reales de Cádiz que ya confían en nuestra tecnología.
            </p>
          </div>

          <!-- Grid de Proyectos -->
          <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
            {
