    <!-- ═══════════════════════════════════════════════════
        SCRIPTS — Interactividad y animaciones
        ═══════════════════════════════════════════════════ -->
    <script>
      /**
       * ─── PRELOADER — Scramble "GaDev" + 000→100 ─────
       * Characters resolve progressively into final text
       */
      (function runPreloader() {
        const CHARSET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789@#$%&!<>/";
        const preloader = document.getElementById("preloader");
        const preTitle = document.getElementById("pre-title");
        const preNum = document.getElementById("pre-num");
        const preLine = document.getElementById("pre-line");
        if (!preloader || !preTitle || !preNum || !preLine) return;

        const FINAL_TEXT = "GaDev";
        const SCRAMBLE_STEPS = 36;
        const DURATION_MS = 1600;
        const interval = DURATION_MS / SCRAMBLE_STEPS;
        let frame = 0;

        // Scramble + counter combined
        const timer = setInterval(() => {
          frame++;
          const progress = frame / SCRAMBLE_STEPS;

          // Scramble text
          let display = "";
          const revealed = Math.floor(progress * FINAL_TEXT.length);
          for (let c = 0; c < FINAL_TEXT.length; c++) {
            if (c < revealed) {
              display += FINAL_TEXT[c];
            } else {
              display += CHARSET[Math.floor(Math.random() * CHARSET.length)];
            }
          }
          preTitle.textContent = display;

          // Counter 000 → 100
          const val = Math.round(progress * 100);
          preNum.textContent = String(val).padStart(3, "0");

          // Progress line
          preLine.style.width = val + "%";

          if (frame >= SCRAMBLE_STEPS) {
            clearInterval(timer);
            preTitle.textContent = FINAL_TEXT;
            preNum.textContent = "100";
            preLine.style.width = "100%";

            // Fade out preloader after a tiny pause
            setTimeout(() => {
              preloader.style.opacity = "0";
              preloader.style.pointerEvents = "none";

              // Remove from DOM after fade transition
              setTimeout(() => {
                preloader.style.display = "none";
                // Trigger hero animations
                document.body.classList.add("preloader-done");
              }, 500);
            }, 200);
          }
        }, interval);
      })();

      /**
       * ─── Spotlight Cards — Pointer tracking ─────────
       * Updates CSS custom properties with CARD-RELATIVE coords
       */
      document.addEventListener("pointermove", (e) => {
        const cards = Array.from(document.querySelectorAll(".glow-card"));

        // 1. READ phase (batching reads prevents layout thrashing & lag)
        const rects = cards.map((card) => card.getBoundingClientRect());

        // 2. WRITE phase
        const clientX = e.clientX;
        const clientY = e.clientY;
        const xp = (clientX / window.innerWidth).toFixed(2);

        cards.forEach((card, index) => {
          const htmlCard = card as HTMLElement;
          const rect = rects[index];
          const x = clientX - rect.left;
          const y = clientY - rect.top;
          htmlCard.style.setProperty("--x", x.toFixed(2));
          htmlCard.style.setProperty("--y", y.toFixed(2));
          htmlCard.style.setProperty("--xp", xp);
        });
      });

      /**
       * ─── Navbar Scroll-Blur ─────────────────────────
       * Añade fondo translúcido y blur al hacer scroll
       */
      const navbar = document.getElementById("navbar");
      const handleScroll = () => {
        if (!navbar) return;
        if (window.scrollY > 50) {
          navbar.style.background = "rgba(3, 3, 3, 0.8)";
          navbar.style.backdropFilter = "blur(20px) saturate(1.8)";
          navbar.style.borderBottom = "1px solid rgba(255,255,255,0.05)";
        } else {
          navbar.style.background = "transparent";
          navbar.style.backdropFilter = "none";
          navbar.style.borderBottom = "1px solid transparent";
        }
      };
      window.addEventListener("scroll", handleScroll, { passive: true });
      handleScroll();

      /**
       * ─── Mobile Menu Toggle ─────────────────────────
       */
      const menuBtn = document.getElementById("mobile-menu-btn");
      const mobileMenu = document.getElementById("mobile-menu");
      let menuOpen = false;

      menuBtn?.addEventListener("click", () => {
        menuOpen = !menuOpen;
        if (mobileMenu) {
          if (menuOpen) {
            mobileMenu.style.opacity = "1";
            mobileMenu.style.pointerEvents = "auto";
          } else {
            mobileMenu.style.opacity = "0";
            mobileMenu.style.pointerEvents = "none";
          }
        }
        menuBtn.setAttribute("aria-expanded", String(menuOpen));
        // Animación de las líneas del hamburger
        const lines = menuBtn.querySelectorAll(".hamburger-line");
        if (menuOpen) {
          (lines[0] as HTMLElement).style.transform =
            "translateY(8px) rotate(45deg)";
          (lines[1] as HTMLElement).style.opacity = "0";
          (lines[2] as HTMLElement).style.transform =
            "translateY(-8px) rotate(-45deg)";
          (lines[2] as HTMLElement).style.width = "24px";
        } else {
          (lines[0] as HTMLElement).style.transform = "none";
          (lines[1] as HTMLElement).style.opacity = "1";
          (lines[2] as HTMLElement).style.transform = "none";
          (lines[2] as HTMLElement).style.width = "16px";
        }
      });

      // Cerrar menú al hacer click en un link mobile
      mobileMenu?.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => {
          menuOpen = false;
          if (mobileMenu) {
            mobileMenu.style.opacity = "0";
            mobileMenu.style.pointerEvents = "none";
          }
          const lines = menuBtn?.querySelectorAll(".hamburger-line");
          if (lines) {
            (lines[0] as HTMLElement).style.transform = "none";
            (lines[1] as HTMLElement).style.opacity = "1";
            (lines[2] as HTMLElement).style.transform = "none";
            (lines[2] as HTMLElement).style.width = "16px";
          }
          menuBtn?.setAttribute("aria-expanded", "false");
        });
      });

      /**
       * ─── Intersection Observer — Scroll animations ──
       * Aplica animación fade-in-up a elementos con [data-animate]
       */
      const animateOnScroll = () => {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("animate-fade-in-up");
                (entry.target as HTMLElement).style.opacity = "1";
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.1,
            rootMargin: "0px 0px -50px 0px",
          },
        );

        document.querySelectorAll("[data-animate]").forEach((el, index) => {
          (el as HTMLElement).style.opacity = "0";
          (el as HTMLElement).style.animationDelay = `${index * 0.1}s`;
          observer.observe(el);
        });
      };

      // Ejecutar cuando el DOM esté listo
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", animateOnScroll);
      } else {
        animateOnScroll();
      }

      /**
       * ─── Smooth scroll con offset para la navbar ────
       */
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener("click", (e) => {
          const href = anchor.getAttribute("href");
          if (!href || href === "#") return;

          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            const offset = 80; // Altura de la navbar
            const top =
              target.getBoundingClientRect().top + window.scrollY - offset;
            window.scrollTo({ top, behavior: "smooth" });
          }
        });
      });

      /**
       * ─── GSAP & LENIS SETUP ───────────────────────────
       */
      // Inicializar Lenis (Global Smooth Scroll)
      // Usamos window.Lenis ya que lo cargamos vía CDN
      if (typeof window !== "undefined" && (window as any).Lenis) {
        const lenis = new (window as any).Lenis({
          duration: 1.2,
          easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        });
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      // ─── REVEAL FOOTER HEIGHT MARGIN Ajuste (Crucial)
      const mainContent = document.getElementById("main-content");
      const revealFooter = document.getElementById("reveal-footer");
      function updateFooterReveal() {
        if (mainContent && revealFooter) {
          mainContent.style.marginBottom = `${revealFooter.offsetHeight}px`;
        }
      }
      updateFooterReveal();
      window.addEventListener("resize", updateFooterReveal);
      // Fallbacks por si webfonts cambian la altura o se ejecuta antes de tiempo
      document.addEventListener("DOMContentLoaded", updateFooterReveal);
      window.addEventListener("load", updateFooterReveal);
      setTimeout(updateFooterReveal, 1000);

      // Sincronizar ScrollTrigger con Lenis para animaciones
      try {
        const gsap = (window as any).gsap;
        const ScrollTrigger = (window as any).ScrollTrigger;

        gsap.registerPlugin(ScrollTrigger);

        // ─── STAGGERED TEXT SPLIT ("Lleva tu negocio al siguiente nivel.")
        const footerCta = document.getElementById("footer-cta");
        if (footerCta) {
          const text = footerCta.innerText;
          footerCta.innerHTML = "";
          // Partimos string en spans manualmente
          text.split("").forEach((char) => {
            const span = document.createElement("span");
            span.style.display = "inline-block";
            span.innerText = char === " " ? "\u00A0" : char;
            footerCta.appendChild(span);
          });

          gsap.fromTo(
            footerCta.children,
            { y: 120, opacity: 0, rotateZ: 5 },
            {
              y: 0,
              opacity: 1,
              rotateZ: 0,
              stagger: 0.02,
              duration: 1.2,
              ease: "power4.out",
              scrollTrigger: {
                trigger: revealFooter,
                start: "top 80%", // Se activa cuando se revela el 20% del footer
                end: "bottom bottom",
                toggleActions: "play none none reverse",
              },
            },
          );
        }

        // ─── MAGNETIC ITEMS EFFECT (Optimized)
        const magneticItems = document.querySelectorAll(".magnetic-item");

        magneticItems.forEach((el) => {
          // Le decimos que rect puede ser un DOMRect o nulo
          let rect: DOMRect | null = null;

          el.addEventListener("mouseenter", () => {
            rect = el.getBoundingClientRect();
          });

          // Le decimos que la 'e' es un MouseEvent
          el.addEventListener("mousemove", (e: Event) => {
            const mouseEvent = e as MouseEvent;
            if (!rect) rect = el.getBoundingClientRect();

            const x = (mouseEvent.clientX - rect.left - rect.width / 2) * 0.4;
            const y = (mouseEvent.clientY - rect.top - rect.height / 2) * 0.4;
            gsap.to(el, { x, y, duration: 0.4, ease: "power2.out" });
          });

          el.addEventListener("mouseleave", () => {
            rect = null;
            gsap.to(el, {
              x: 0,
              y: 0,
              duration: 0.8,
              ease: "elastic.out(1, 0.3)",
            });
          });
        });
      } catch (err) {
        console.warn(
          "GSAP/ScrollTrigger no cargado completamente todavía",
          err,
        );
      }

      // ─── DIGITAL CLOCK TERMINAL EFFECT
      const clockEl = document.getElementById("footer-clock");
      if (clockEl) {
        setInterval(() => {
          const d = new Date();
          const format = (n: number) => String(n).padStart(2, "0");
          clockEl.innerText = `${format(d.getHours())}:${format(d.getMinutes())}:${format(d.getSeconds())}`;
        }, 1000);
      }
    </script>
