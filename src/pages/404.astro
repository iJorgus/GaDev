---
/**
 * ═══════════════════════════════════════════════════════
 *  404.astro — Página de error personalizada
 *  Estética Dark Room + Cádiz Sunset
 * ═══════════════════════════════════════════════════════
 */

import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

const seo = {
  title: "404 — Página no encontrada | GaDev",
  description: "La página que buscas no existe o ha sido movida.",
  url: "https://gadev.es/404",
  image: "https://gadev.es/og-image.jpg",
};
---

<Layout
  title={seo.title}
  description={seo.description}
  url={seo.url}
  image={seo.image}
>
  <main class="relative z-10 bg-[#030303] min-h-screen">
    <Navbar />

    <section
      class="flex min-h-screen flex-col items-center justify-center px-6 text-center"
    >
      <!-- Error code -->
      <div class="mb-8 relative">
        <span
          class="text-[10rem] sm:text-[14rem] md:text-[18rem] font-black leading-none tracking-tighter gradient-text select-none opacity-20"
        >
          404
        </span>
        <div class="absolute inset-0 flex items-center justify-center">
          <span
            class="text-6xl sm:text-7xl md:text-8xl font-black tracking-tighter gradient-text"
          >
            404
          </span>
        </div>
      </div>

      <!-- Message -->
      <h1
        class="mb-4 text-2xl font-bold tracking-tight text-text-primary sm:text-3xl md:text-4xl"
      >
        Esto no es Cádiz
      </h1>
      <p
        class="mb-10 max-w-md text-base leading-relaxed text-text-secondary md:text-lg"
      >
        Parece que te has perdido entre callejones. La página que buscas no
        existe o ha cambiado de dirección.
      </p>

      <!-- CTA -->
      <a
        href="/"
        class="group inline-flex items-center gap-2 rounded-full px-8 py-4 text-base font-semibold text-white transition-all duration-300 hover:scale-105 hover:shadow-lg hover:shadow-cadiz-ocean/25"
        style="background: linear-gradient(135deg, #0077b6, #0096c7, #ee9b00);"
      >
        <svg
          class="h-5 w-5 transition-transform duration-300 group-hover:-translate-x-1"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M19 12H5"></path>
          <path d="m12 19-7-7 7-7"></path>
        </svg>
        <span>Volver al inicio</span>
      </a>

      <!-- Location tag -->
      <p
        class="mt-16 flex items-center gap-2 text-xs tracking-widest text-text-muted uppercase font-mono"
      >
        <svg
          class="h-3.5 w-3.5"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
          ></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <span>Ubicación desconocida</span>
      </p>
    </section>
  </main>
</Layout>
