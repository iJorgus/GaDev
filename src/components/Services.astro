---
/**
 * ═══════════════════════════════════════════════════════
 *  Services.astro — Bento Grid interactivo de servicios
 * ═══════════════════════════════════════════════════════
 */

/** Servicios ofrecidos por GaDev */
const servicios = [
  {
    id: "web-apps",
    titulo: "Aplicaciones Web",
    descripcion:
      "Plataformas digitales a medida que transforman la forma en que tu negocio gaditano se conecta con sus clientes. Desde paneles de administración hasta apps progresivas.",
    icono: "globe",
    gridClass: "md:col-span-2",
    acento: "from-[#0077b6] to-[#0096c7]",
    destacado: true,
    features: [
      "Apps progresivas (PWA)",
      "Paneles de administración",
      "APIs robustas",
    ],
  },
  {
    id: "ecommerce",
    titulo: "E-Commerce Local",
    descripcion:
      "Tiendas online con sabor a Cádiz. Vende tus productos al mundo sin perder tu identidad local.",
    icono: "shopping-bag",
    gridClass: "",
    acento: "from-[#0096c7] to-[#48cae4]",
  },
  {
    id: "booking",
    titulo: "Reservas y Citas",
    descripcion:
      "Sistemas de reserva inteligentes para hostelería, salud y servicios profesionales de Cádiz.",
    icono: "calendar-check",
    gridClass: "",
    acento: "from-[#48cae4] to-[#90e0ef]",
  },
  {
    id: "automatizacion",
    titulo: "Automatización",
    descripcion:
      "Eliminamos las tareas repetitivas de tu negocio con flujos de trabajo inteligentes y conectados.",
    icono: "cpu",
    gridClass: "",
    acento: "from-[#ee9b00] to-[#ffb703]",
  },
  {
    id: "seo-local",
    titulo: "SEO & Presencia Digital",
    descripcion:
      "Haz que te encuentren en Cádiz. Posicionamiento local y estrategia digital para crecer.",
    icono: "search",
    gridClass: "",
    acento: "from-[#0077b6] to-[#ee9b00]",
  },
  {
    id: "consultoria",
    titulo: "Consultoría Tech",
    descripcion:
      "Asesoramiento técnico para digitalizar tu negocio con la solución correcta, sin gastar de más.",
    icono: "lightbulb",
    gridClass: "md:col-span-2",
    acento: "from-[#ffb703] to-[#ee9b00]",
    destacado: true,
    features: [
      "Auditoría tecnológica",
      "Plan de digitalización",
      "Presupuesto sin sorpresas",
    ],
  },
];
---

<section
  id="servicios"
  class="relative z-10 py-24"
  aria-label="Nuestros servicios"
>
  <div class="mx-auto max-w-6xl px-6 lg:px-8">
    <!-- Header de sección -->
    <div class="mb-16 text-center" data-animate>
      <span
        class="inline-block mb-4 text-sm font-semibold tracking-widest text-cadiz-amber uppercase"
        >Lo que hacemos</span
      >
      <h2
        class="mb-4 text-3xl font-bold tracking-tight md:text-4xl lg:text-5xl"
      >
        Servicios <span class="gradient-text">a tu medida</span>
      </h2>
      <p class="mx-auto max-w-2xl text-text-secondary">
        Cada negocio gaditano es único. Por eso nuestras soluciones se
        diseñan desde cero, adaptadas a tus necesidades reales.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
      {
        servicios.map((servicio, index) => (
          <article
            class={`glow-card group relative cursor-pointer overflow-hidden rounded-2xl p-6 transition-all duration-500 hover:scale-[1.02] md:p-8 ${servicio.gridClass}`}
            data-glow
            data-animate
            id={`servicio-${servicio.id}`}
            role="article"
            aria-label={`Servicio: ${servicio.titulo}`}
          >
            {/* Spotlight inner glow layer */}
            <div data-glow aria-hidden="true" />
            {/* Glow decorativo de fondo */}
            <div
              class={`absolute -right-4 -bottom-4 h-32 w-32 rounded-full bg-gradient-to-br ${servicio.acento} opacity-5 transition-all duration-500 group-hover:opacity-10 group-hover:scale-125`}
              aria-hidden="true"
            />

            {/* Icono con gradiente */}
            <div
              class={`mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br ${servicio.acento} p-2.5 shadow-lg transition-transform duration-300 group-hover:scale-110`}
            >
              <svg
                class="h-6 w-6 text-white"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                {servicio.id === "web-apps" && (
                  <>
                    <circle cx="12" cy="12" r="10" />
                    <path d="M2 12h20" />
                    <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
                  </>
                )}
                {servicio.id === "ecommerce" && (
                  <>
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
                    <path d="M3 6h18" />
                    <path d="M16 10a4 4 0 0 1-8 0" />
                  </>
                )}
                {servicio.id === "booking" && (
                  <>
                    <rect width="18" height="18" x="3" y="4" rx="2" />
                    <path d="M16 2v4" />
                    <path d="M8 2v4" />
                    <path d="M3 10h18" />
                    <path d="m9 16 2 2 4-4" />
                  </>
                )}
                {servicio.id === "automatizacion" && (
                  <>
                    <rect width="16" height="16" x="4" y="4" rx="2" />
                    <rect width="6" height="6" x="9" y="9" rx="1" />
                    <path d="M15 2v2" />
                    <path d="M15 20v2" />
                    <path d="M2 15h2" />
                    <path d="M2 9h2" />
                    <path d="M20 15h2" />
                    <path d="M20 9h2" />
                    <path d="M9 2v2" />
                    <path d="M9 20v2" />
                  </>
                )}
                {servicio.id === "seo-local" && (
                  <>
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.3-4.3" />
                  </>
                )}
                {servicio.id === "consultoria" && (
                  <>
                    <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
                    <path d="M9 18h6" />
                    <path d="M10 22h4" />
                  </>
                )}
              </svg>
            </div>

            {/* Contenido */}
            <h3 class="mb-2 text-lg font-bold text-text-primary md:text-xl">
              {servicio.titulo}
            </h3>
            <p class="mb-4 text-sm leading-relaxed text-text-secondary md:text-base">
              {servicio.descripcion}
            </p>

            {/* Feature badges para tarjetas destacadas */}
            {servicio.destacado && servicio.features && (
              <div class="mb-4 flex flex-wrap gap-2">
                {servicio.features.map((feature: string) => (
                  <span class="inline-flex items-center gap-1 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium text-text-secondary">
                    <svg
                      class="h-3 w-3 text-cadiz-ocean"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    {feature}
                  </span>
                ))}
              </div>
            )}

            {/* Flecha de acción */}
            <div class="mt-auto flex items-center gap-1 text-sm font-medium text-cadiz-ocean transition-all duration-300 group-hover:text-cadiz-amber group-hover:gap-2">
              <span>Saber más</span>
              <svg
                class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14" />
                <path d="m12 5 7 7-7 7" />
              </svg>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
